generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

type OrderItems {
  category    OrderItemsCategory
  categoryId  String
  createdAt   String
  description String
  id          String
  images      String[]
  name        String
  price       Float
  quantity    Int
  rating      Float
  slug        String
  stock       Int
}

type OrderItemsCategory {
  id   String
  name String
  slug String
}

model Category {
  id      String    @id @default(auto()) @map("_id") @db.ObjectId
  name    String
  slug    String
  Product Product[]
}

model Order {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  address       String
  createdAt     DateTime     @db.Date
  items         OrderItems[]
  paymentMethod String
  status        String
  totalAmount   Float
  userId        String       @db.ObjectId
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  price       Float
  rating      Float
  slug        String
  stock       BigInt
  images      String[]
  createdAt   DateTime @db.Date

  // 1. أضف حقل العلاقة هنا
  category Category @relation(fields: [categoryId], references: [id])

  // 2. تأكد أن الحقل المستخدم كـ Foreign Key يحمل نوع @db.ObjectId
  categoryId String @db.ObjectId
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @db.Date
  email     String   @unique
  image     String?
  name      String
  password  String
  role      String
  updatedAt DateTime @db.Date
}
